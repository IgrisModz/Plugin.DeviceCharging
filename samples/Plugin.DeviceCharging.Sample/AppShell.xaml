<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Plugin.DeviceCharging.Sample.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Plugin.DeviceCharging.Sample"
    xmlns:mi="http://www.igrismodz.com/dotnet/2026/maui/icons"
    Title="Plugin.DeviceCharging.Sample"
    Shell.NavBarIsVisible="False">

    <TabBar>
        <ShellContent
            Title="Home"
            Icon="{mi:MaterialRound Icon=Home}"
            ContentTemplate="{DataTemplate local:MainPage}"
            Route="MainPage" />
        <ShellContent
            Title="Settings"
            Icon="{mi:MaterialRound Icon=Settings}"
            ContentTemplate="{DataTemplate local:SettingsPage}"
            Route="SettingsPage" />
    </TabBar>

</Shell>
